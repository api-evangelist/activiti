{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api-evangelist.github.io/activiti/json-schema/activiti-userrepresentation.json",
  "title": "UserRepresentation",
  "description": "Activiti UserRepresentation schema",
  "properties": {
    "apps": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/LightAppRepresentation"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "company": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "email": {
      "type": "string"
    },
    "externalId": {
      "type": "string"
    },
    "firstName": {
      "type": "string"
    },
    "fullname": {
      "type": "string"
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/GroupRepresentation"
      }
    },
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "lastName": {
      "type": "string"
    },
